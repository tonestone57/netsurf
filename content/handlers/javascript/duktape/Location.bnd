%}


getter Location::search()
%{
	char *url_s = NULL;
	size_t url_l;

	nsurl_get(priv->url, NSURL_QUERY, &url_s, &url_l);

	/* if url_s is NULL duk_push_lstring pushes an empty string
	 * which is correct for this API
	 */
	duk_push_lstring(ctx, url_s, url_l);

	if (url_s != NULL) {
		free(url_s);
	}

	return 1;
%}

setter Location::search()
%{
	/* retrieve the private data from the root object (window) */
	duk_push_global_object(ctx);
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	window_private_t *priv_win = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	if (priv_win == NULL || priv_win->win == NULL) {
		return 0;
	}

	const char *s = duk_safe_to_string(ctx, 0);
	if (s[0] == '?') s++;

	nsurl *new_url;
	nsurl_replace_query(priv->url, s, &new_url);

	browser_window_navigate(priv_win->win, new_url, NULL, BW_NAVIGATE_HISTORY, NULL, NULL, NULL);
	nsurl_unref(new_url);
	return 0;
%}

getter Location::hash()
%{
	char *url_s = NULL;
	size_t url_l;

	nsurl_get(priv->url, NSURL_FRAGMENT, &url_s, &url_l);

	/* if url_s is NULL duk_push_lstring pushes an empty string
	 * which is correct for this API
	 */
	duk_push_lstring(ctx, url_s, url_l);

	if (url_s != NULL) {
		free(url_s);
	}

	return 1;
%}

setter Location::hash()
%{
	/* retrieve the private data from the root object (window) */
	duk_push_global_object(ctx);
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	window_private_t *priv_win = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	if (priv_win == NULL || priv_win->win == NULL) {
		return 0;
	}

	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);
	if (slen > 0 && s[0] == '#') { s++; slen--; }

	lwc_string *frag;
	if (lwc_intern_string(s, slen, &frag) != lwc_error_ok) return 0;

	nsurl *new_url;
	nsurl_refragment(priv->url, frag, &new_url);
	lwc_string_unref(frag);

	browser_window_navigate(priv_win->win, new_url, NULL, BW_NAVIGATE_HISTORY, NULL, NULL, NULL);
	nsurl_unref(new_url);
	return 0;
%}

