%}

setter Location::port()
%{
	/* retrieve the private data from the root object (window) */
	duk_push_global_object(ctx);
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	window_private_t *priv_win = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	if (priv_win == NULL || priv_win->win == NULL) {
		return 0;
	}

	char *host_s = NULL;
	size_t host_l = 0;
	nsurl_get(priv->url, NSURL_HOST, &host_s, &host_l);

	char *path_s = NULL;
	size_t path_l = 0;
	nsurl_get(priv->url, NSURL_PATH | NSURL_QUERY | NSURL_FRAGMENT, &path_s, &path_l);

	const char *new_port = duk_safe_to_string(ctx, 0);
	duk_push_sprintf(ctx, "//%s:%s%s", (host_s != NULL ? host_s : ""), new_port, (path_s != NULL ? path_s : "/"));
	const char *rel = duk_get_string(ctx, -1);

	nsurl *new_url;
	nsurl_join(priv->url, rel, &new_url);

	browser_window_navigate(priv_win->win, new_url, NULL, BW_NAVIGATE_HISTORY, NULL, NULL, NULL);
	nsurl_unref(new_url);

	duk_pop(ctx);
	free(host_s);
	free(path_s);
	return 0;
%}

