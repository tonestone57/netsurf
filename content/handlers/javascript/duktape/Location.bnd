getter Location::host()
%{
	char *url_s = NULL;
	size_t url_l;

	nsurl_get(priv->url, NSURL_HOST | NSURL_PORT, &url_s, &url_l);

	/* if url_s is NULL duk_push_lstring pushes an empty string
	 * which is correct for this API
	 */
	duk_push_lstring(ctx, url_s, url_l);

	if (url_s != NULL) {
		free(url_s);
	}

	return 1;
%}

setter Location::host()
%{
	/* retrieve the private data from the root object (window) */
	duk_push_global_object(ctx);
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	window_private_t *priv_win = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	if (priv_win == NULL || priv_win->win == NULL) {
		return 0;
	}

	char *path_s = NULL;
	size_t path_l = 0;
	nsurl_get(priv->url, NSURL_PATH | NSURL_QUERY | NSURL_FRAGMENT, &path_s, &path_l);

	const char *new_host = duk_safe_to_string(ctx, 0);
	duk_push_sprintf(ctx, "//%s%s", new_host, (path_s != NULL ? path_s : "/"));
	const char *rel = duk_get_string(ctx, -1);

	nsurl *new_url;
	nsurl_join(priv->url, rel, &new_url);

	browser_window_navigate(priv_win->win, new_url, NULL, BW_NAVIGATE_HISTORY, NULL, NULL, NULL);
	nsurl_unref(new_url);

	duk_pop(ctx);
	free(path_s);
	return 0;
%}

getter Location::hostname()
%{
	char *url_s = NULL;
	size_t url_l;

	nsurl_get(priv->url, NSURL_HOST, &url_s, &url_l);

	/* if url_s is NULL duk_push_lstring pushes an empty string
	 * which is correct for this API
	 */
	duk_push_lstring(ctx, url_s, url_l);

	if (url_s != NULL) {
		free(url_s);
	}

	return 1;
%}

setter Location::hostname()
%{
	/* retrieve the private data from the root object (window) */
	duk_push_global_object(ctx);
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	window_private_t *priv_win = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	if (priv_win == NULL || priv_win->win == NULL) {
		return 0;
	}

	char *port_s = NULL;
	size_t port_l = 0;
	nsurl_get(priv->url, NSURL_PORT, &port_s, &port_l);

	char *path_s = NULL;
	size_t path_l = 0;
	nsurl_get(priv->url, NSURL_PATH | NSURL_QUERY | NSURL_FRAGMENT, &path_s, &path_l);

	const char *new_hostname = duk_safe_to_string(ctx, 0);
	duk_push_sprintf(ctx, "//%s%s%s%s", new_hostname, (port_s != NULL ? ":" : ""), (port_s != NULL ? port_s : ""), (path_s != NULL ? path_s : "/"));
	const char *rel = duk_get_string(ctx, -1);

	nsurl *new_url;
	nsurl_join(priv->url, rel, &new_url);

	browser_window_navigate(priv_win->win, new_url, NULL, BW_NAVIGATE_HISTORY, NULL, NULL, NULL);
	nsurl_unref(new_url);

	duk_pop(ctx);
	free(port_s);
	free(path_s);
	return 0;
%}

