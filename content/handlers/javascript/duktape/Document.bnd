prologue Document()
%{
#include "javascript/duktape/dukky.h"
#include "utils/corestrings.h"
#include "utils/libdom.h"
#include "utils/utils.h"
#include "content/hlcache.h"
#include "html/private.h"
#include "content/urldb.h"
#include "content/llcache.h"
#include <time.h>

#define HANDLER_MAGIC MAGIC(HANDLER_MAP)

static int dukky_document_push_url(duk_context *ctx, node_private_t *priv)
{
	dom_exception err;
	dom_string *url;

	err = dom_html_document_get_url((dom_html_document *)priv->node, &url);
	if (err != DOM_NO_ERR || url == NULL) {
		struct html_content *htmlc;
		err = dom_node_get_user_data(priv->node,
					     corestring_dom___ns_key_html_content_data,
					     &htmlc);
		if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
			duk_push_string(ctx, nsurl_access(llcache_handle_get_url(htmlc->base.llcache)));
			return 1;
		}
		return 0;
	}

	duk_push_lstring(ctx, dom_string_data(url), dom_string_byte_length(url));
	dom_string_unref(url);

	return 1;
}
%}


init Document(struct dom_document *document::node);

method Document::write()
%{
	struct html_content *htmlc;
	duk_size_t text_len;
	dom_exception err;
	const char *text;

	for (int i = 0; i < duk_get_top(ctx); ++i) {
		duk_safe_to_string(ctx, i);
	}
	duk_concat(ctx, duk_get_top(ctx));
	text = duk_safe_to_lstring(ctx, 0, &text_len);
	NSLOG(netsurf, DEBUG, "Writing %*s", (int)text_len, text);

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err != DOM_NO_ERR) || (htmlc == NULL)) {
		NSLOG(netsurf, INFO,
		      "error getting htmlc. parent node:%p htmlc:%p",
		      priv->parent.node, htmlc);
		return 0;
	} else if (htmlc->parser == NULL) {
		NSLOG(netsurf, INFO, "error; no parser for htmlc: %p", htmlc);
		return 0;
	}

	dom_hubbub_parser_insert_chunk(htmlc->parser,
			(uint8_t *)text, text_len);

	return 0;
%}

method Document::writeln()
%{
	const char nl[] = "\n";
	struct html_content *htmlc;
	duk_size_t text_len;
	const char *text;
	dom_exception err;

	for (int i = 0; i < duk_get_top(ctx); ++i) {
		duk_safe_to_string(ctx, i);
	}
	duk_concat(ctx, duk_get_top(ctx));
	text = duk_safe_to_lstring(ctx, 0, &text_len);

	NSLOG(netsurf, DEBUG, "Writeln %*s", (int)text_len, text);
	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err != DOM_NO_ERR) || (htmlc == NULL)) {
		NSLOG(netsurf, INFO,
		      "error getting htmlc. parent node:%p htmlc:%p",
		      priv->parent.node, htmlc);
		return 0;
	} else if (htmlc->parser == NULL) {
		NSLOG(netsurf, INFO, "error; no parser for htmlc: %p", htmlc);
		return 0;
	}

	dom_hubbub_parser_insert_chunk(htmlc->parser, (uint8_t *)text, text_len);
	dom_hubbub_parser_insert_chunk(htmlc->parser, (uint8_t *)nl, SLEN(nl));

	return 0;
%}

method Document::createTextNode()
%{
	dom_node *newnode;
	dom_exception err;
	duk_size_t text_len;
	const char *text = duk_safe_to_lstring(ctx, 0, &text_len);
	dom_string *text_str;

	err = dom_string_create((const uint8_t *)text, text_len, &text_str);
	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	err = dom_document_create_text_node(priv->parent.node,
					    text_str,
					    &newnode);
	if (err != DOM_NO_ERR) {
		dom_string_unref(text_str);
		return 0; /* coerced to undefined */
	}

	dom_string_unref(text_str);

	dukky_push_node(ctx, newnode);
	dom_node_unref(newnode);

	return 1;
%}

method Document::createComment()
%{
	dom_node *newnode;
	dom_exception err;
	duk_size_t text_len;
	const char *text = duk_safe_to_lstring(ctx, 0, &text_len);
	dom_string *text_str;

	err = dom_string_create((const uint8_t *)text, text_len, &text_str);
	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	err = dom_document_create_comment(priv->parent.node,
					    text_str,
					    &newnode);
	if (err != DOM_NO_ERR) {
		dom_string_unref(text_str);
		return 0; /* coerced to undefined */
	}

	dom_string_unref(text_str);

	dukky_push_node(ctx, newnode);
	dom_node_unref(newnode);

	return 1;
%}

method Document::createProcessingInstruction()
%{
	dom_node *newnode;
	dom_exception err;
	duk_size_t t_len, d_len;
	const char *target = duk_safe_to_lstring(ctx, 0, &t_len);
	const char *data = duk_safe_to_lstring(ctx, 1, &d_len);
	dom_string *t_str, *d_str;

	err = dom_string_create((const uint8_t *)target, t_len, &t_str);
	if (err != DOM_NO_ERR) return 0;

	err = dom_string_create((const uint8_t *)data, d_len, &d_str);
	if (err != DOM_NO_ERR) {
		dom_string_unref(t_str);
		return 0;
	}

	err = dom_document_create_processing_instruction(priv->parent.node,
					    t_str, d_str,
					    (dom_processing_instruction **)&newnode);
	dom_string_unref(t_str);
	dom_string_unref(d_str);

	if (err != DOM_NO_ERR) return 0;

	dukky_push_node(ctx, newnode);
	dom_node_unref(newnode);

	return 1;
%}

method Document::createAttribute()
%{
	dom_node *newnode;
	dom_exception err;
	duk_size_t name_len;
	const char *name = duk_safe_to_lstring(ctx, 0, &name_len);
	dom_string *name_str;

	err = dom_string_create((const uint8_t *)name, name_len, &name_str);
	if (err != DOM_NO_ERR) return 0;

	err = dom_document_create_attribute(priv->parent.node,
					    name_str,
					    (dom_attr **)&newnode);
	dom_string_unref(name_str);

	if (err != DOM_NO_ERR) return 0;

	dukky_push_node(ctx, newnode);
	dom_node_unref(newnode);

	return 1;
%}


getter Document::characterSet()
%{
	struct html_content *htmlc;
	dom_exception err;

	if (priv == NULL || priv->parent.node == NULL) { duk_push_string(ctx, "UTF-8"); return 1; }

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		duk_push_string(ctx, htmlc->encoding ? htmlc->encoding : "UTF-8");
		return 1;
	}
	duk_push_string(ctx, "UTF-8");
	return 1;
%}

getter Document::charset()
%{
	dom_exception err;
	struct html_content *htmlc;

	if (priv == NULL || priv->parent.node == NULL) { duk_push_string(ctx, "UTF-8"); return 1; }

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		duk_push_string(ctx, htmlc->encoding ? htmlc->encoding : "UTF-8");
		return 1;
	}
	duk_push_string(ctx, "UTF-8");
	return 1;
%}

