%}

getter Document::contentType()
%{
	struct html_content *htmlc;
	dom_exception err;

	if (priv == NULL || priv->parent.node == NULL) { duk_push_string(ctx, "application/xml"); return 1; }

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		duk_push_string(ctx, "text/html"); /* NetSurf HTML content is always text/html */
		return 1;
	}
	duk_push_string(ctx, "application/xml");
	return 1;
%}

getter Document::title()
%{
	struct html_content *htmlc;
	dom_exception err;
	dom_string *title_str;
	dom_node *title_node = NULL;

	if (priv == NULL || priv->parent.node == NULL) return 0;

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err != DOM_NO_ERR) || (htmlc == NULL)) {
		return 0;
	}

	title_node = htmlc->title;
	if (title_node == NULL) {
		dom_nodelist *nodes;
		err = dom_document_get_elements_by_tag_name(priv->parent.node,
							    corestring_dom_TITLE,
							    &nodes);
		if (err == DOM_NO_ERR && nodes != NULL) {
			dom_nodelist_item(nodes, 0, &title_node);
			dom_nodelist_unref(nodes);
		}
	} else {
		dom_node_ref(title_node);
	}

	if (title_node != NULL) {
		err = dom_node_get_text_content(title_node, &title_str);
		dom_node_unref(title_node);
		if (err == DOM_NO_ERR && title_str != NULL) {
			duk_push_lstring(ctx, dom_string_data(title_str),
					 dom_string_byte_length(title_str));
			dom_string_unref(title_str);
			return 1;
		}
	}

	duk_push_string(ctx, "");
	return 1;
%}

setter Document::title()
%{
	struct html_content *htmlc;
	dom_exception err;
	duk_size_t text_len;
	const char *text = duk_safe_to_lstring(ctx, 0, &text_len);
	dom_string *text_str;

	if (priv == NULL || priv->parent.node == NULL) return 0;

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err != DOM_NO_ERR) || (htmlc == NULL)) {
		return 0;
	}

	err = dom_string_create((const uint8_t *)text, text_len, &text_str);
	if (err != DOM_NO_ERR) return 0;

	if (htmlc->title == NULL) {
		dom_nodelist *nodes;
		err = dom_document_get_elements_by_tag_name(priv->parent.node,
							    corestring_dom_TITLE,
							    &nodes);
		if (err == DOM_NO_ERR && nodes != NULL) {
			dom_nodelist_item(nodes, 0, &htmlc->title);
			dom_nodelist_unref(nodes);
		}
	}

	if (htmlc->title != NULL) {
		dom_node_set_text_content(htmlc->title, text_str);
	} else {
		/* Create a new title element */
		dom_node *head = NULL;
		dom_nodelist *nodes;
		err = dom_document_get_elements_by_tag_name(priv->parent.node,
							    corestring_dom_HEAD,
							    &nodes);
		if (err == DOM_NO_ERR && nodes != NULL) {
			dom_nodelist_item(nodes, 0, &head);
			dom_nodelist_unref(nodes);
		}

		if (head != NULL) {
			dom_node *title_ele;
			dom_node *spare = NULL;
			err = dom_document_create_element_ns(priv->parent.node,
							     corestring_dom_html_namespace,
							     corestring_dom_TITLE,
							     (dom_element **)&title_ele);
			if (err == DOM_NO_ERR) {
				dom_node_set_text_content(title_ele, text_str);
				dom_node_append_child(head, title_ele, &spare);
				if (spare != NULL) {
					dom_node_unref(spare);
				}
				htmlc->title = dom_node_ref(title_ele);
				dom_node_unref(title_ele);
			}
			dom_node_unref(head);
		}
	}

	dom_string_unref(text_str);
	return 0;
%}

getter Document::URL()
%{
	return dukky_document_push_url(ctx, (node_private_t *)priv);
%}

getter Document::documentURI()
%{
	return dukky_document_push_url(ctx, (node_private_t *)priv);
%}

getter Document::referrer()
%{
	dom_exception err;
	dom_string *referrer;

	err = dom_html_document_get_referrer((dom_html_document *)priv->parent.node, &referrer);
	if (err != DOM_NO_ERR || referrer == NULL) {
		duk_push_string(ctx, "");
		return 1;
	}

	duk_push_lstring(ctx, dom_string_data(referrer), dom_string_byte_length(referrer));
	dom_string_unref(referrer);

	return 1;
%}

getter Document::domain()
%{
	dom_exception err;
	dom_string *domain;

	err = dom_html_document_get_domain((dom_html_document *)priv->parent.node, &domain);
	if (err != DOM_NO_ERR || domain == NULL) return 0;

	duk_push_lstring(ctx, dom_string_data(domain), dom_string_byte_length(domain));
	dom_string_unref(domain);

	return 1;
%}

setter Document::domain()
%{
	/* Setting document.domain is currently not supported by libdom.
	 * Any value passed is currently ignored.
	 */
	return 0;
%}

getter Document::hidden()
%{
	duk_push_boolean(ctx, false); /* NetSurf doesn't really support page visibility yet */
	return 1;
%}

getter Document::visibilityState()
%{
	duk_push_string(ctx, "visible");
	return 1;
%}

getter Document::lastModified()
%{
	struct html_content *htmlc;
	dom_exception err;
	const char *last_mod;

	if (priv == NULL || priv->parent.node == NULL) return 0;

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		last_mod = llcache_handle_get_header(htmlc->base.llcache, "Last-Modified");
		if (last_mod != NULL) {
			duk_push_string(ctx, last_mod);
		} else {
			/* Fallback to current date/time if no header */
			time_t now = time(NULL);
			struct tm *tm_ptr = localtime(&now);
			if (tm_ptr) {
				char buf[32];
				strftime(buf, sizeof(buf), "%m/%d/%Y %H:%M:%S", tm_ptr);
				duk_push_string(ctx, buf);
			} else {
				duk_push_string(ctx, "01/01/1970 00:00:00");
			}
		}
		return 1;
	}
	return 0;
%}

getter Document::readyState()
%{
	struct html_content *htmlc;
	dom_exception err;

	if (priv == NULL || priv->parent.node == NULL) return 0;

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		if (htmlc->base.status == CONTENT_STATUS_DONE) {
			duk_push_string(ctx, "complete");
		} else if (htmlc->parse_completed) {
			duk_push_string(ctx, "interactive");
		} else {
			duk_push_string(ctx, "loading");
		}
		return 1;
	}
	return 0;
%}

getter Document::images()
%{
	dom_exception err;
	dom_html_collection *coll;

	err = dom_html_document_get_images((dom_html_document *)priv->parent.node, &coll);
	if (err != DOM_NO_ERR) return 0;

	dukky_push_generics(ctx, "makeListProxy");
	duk_push_pointer(ctx, coll);
	dukky_create_object(ctx, PROTO_NAME(HTMLCOLLECTION), 1);
	dom_html_collection_unref(coll);

	if (dukky_pcall(ctx, 1, false) != 0) return 0;

	return 1;
%}

