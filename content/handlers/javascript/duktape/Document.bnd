getter Document::scripts()
%{
	dom_nodelist *nodes;
	dom_exception err;

	err = dom_document_get_elements_by_tag_name(priv->parent.node,
						    corestring_dom_SCRIPT, &nodes);
	if (err != DOM_NO_ERR || nodes == NULL) return 0;

	dukky_push_generics(ctx, "makeListProxy");
	duk_push_pointer(ctx, nodes);
	dukky_create_object(ctx, PROTO_NAME(NODELIST), 1);
	dom_nodelist_unref(nodes);

	if (dukky_pcall(ctx, 1, false) != 0) return 0;

	return 1;
%}

method Document::createElement()
%{
	dom_node *newnode;
	dom_exception err;
	duk_size_t text_len;
	const char *text = duk_safe_to_lstring(ctx, 0, &text_len);
	dom_string *text_str;

	err = dom_string_create((const uint8_t *)text, text_len, &text_str);
	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	err = dom_document_create_element_ns(priv->parent.node,
					     corestring_dom_html_namespace,
					     text_str,
					     &newnode);
	if (err != DOM_NO_ERR) {
		dom_string_unref(text_str);
		return 0; /* coerced to undefined */
	}

	dom_string_unref(text_str);

	dukky_push_node(ctx, newnode);

	dom_node_unref(newnode);

	return 1;
%}

method Document::createElementNS()
%{
	dom_node *newnode;
	dom_exception err;
	duk_size_t qn_len, ns_len;
	dom_string *qn_str = NULL;
	dom_string *ns_str = NULL;

	if (!duk_is_null(ctx, 0) && !duk_is_undefined(ctx, 0)) {
		const char *ns = duk_safe_to_lstring(ctx, 0, &ns_len);
		err = dom_string_create((const uint8_t *)ns, ns_len, &ns_str);
		if (err != DOM_NO_ERR) return 0;
	}

	const char *qname = duk_safe_to_lstring(ctx, 1, &qn_len);
	err = dom_string_create((const uint8_t *)qname, qn_len, &qn_str);
	if (err != DOM_NO_ERR) {
		if (ns_str) dom_string_unref(ns_str);
		return 0;
	}

	err = dom_document_create_element_ns(priv->parent.node,
					     ns_str,
					     qn_str,
					     &newnode);
	if (ns_str) dom_string_unref(ns_str);
	dom_string_unref(qn_str);

	if (err != DOM_NO_ERR) return 0;

	dukky_push_node(ctx, newnode);
	dom_node_unref(newnode);

	return 1;
%}

method Document::getElementsByTagNameNS()
%{
	dom_nodelist *nodes;
	dom_exception err;
	duk_size_t ns_len, ln_len;
	const char *ln_str = duk_safe_to_lstring(ctx, 1, &ln_len);
	dom_string *ns = NULL, *ln = NULL;

	if (!duk_is_null(ctx, 0) && !duk_is_undefined(ctx, 0)) {
		const char *ns_str = duk_safe_to_lstring(ctx, 0, &ns_len);
		err = dom_string_create((const uint8_t *)ns_str, ns_len, &ns);
		if (err != DOM_NO_ERR) return 0;
	}

	err = dom_string_create((const uint8_t *)ln_str, ln_len, &ln);
	if (err != DOM_NO_ERR) {
		if (ns) dom_string_unref(ns);
		return 0;
	}

	err = dom_document_get_elements_by_tag_name_ns(priv->parent.node, ns, ln, &nodes);
	if (ns) dom_string_unref(ns);
	dom_string_unref(ln);

	if (err != DOM_NO_ERR) return 0;

	if (nodes == NULL) {
		duk_push_null(ctx);
		return 1;
	}

	dukky_push_generics(ctx, "makeListProxy");
	duk_push_pointer(ctx, nodes);
	dukky_create_object(ctx, PROTO_NAME(NODELIST), 1);
	dom_nodelist_unref(nodes);

	if (dukky_pcall(ctx, 1, false) != 0) return 0;

	return 1;
%}

method Document::createAttributeNS()
%{
	dom_node *attr;
	dom_exception err;
	duk_size_t qn_len;
	const char *qn_str = duk_safe_to_lstring(ctx, 1, &qn_len);
	dom_string *ns = NULL, *qn = NULL;

	if (!duk_is_null(ctx, 0) && !duk_is_undefined(ctx, 0)) {
		duk_size_t ns_len;
		const char *ns_str = duk_safe_to_lstring(ctx, 0, &ns_len);
		err = dom_string_create((const uint8_t *)ns_str, ns_len, &ns);
		if (err != DOM_NO_ERR) return 0;
	}

	err = dom_string_create((const uint8_t *)qn_str, qn_len, &qn);
	if (err != DOM_NO_ERR) {
		if (ns) dom_string_unref(ns);
		return 0;
	}

	err = dom_document_create_attribute_ns(priv->parent.node, ns, qn, (dom_attr **)&attr);
	if (ns) dom_string_unref(ns);
	dom_string_unref(qn);

	if (err != DOM_NO_ERR) return 0;

	if (attr == NULL) {
		duk_push_null(ctx);
		return 1;
	}

	dukky_push_node(ctx, attr);
	dom_node_unref(attr);
	return 1;
%}

method Document::importNode()
%{
	if (!dukky_instanceof(ctx, 0, PROTO_NAME(NODE))) return 0;
	duk_get_prop_string(ctx, 0, PRIVATE_MAGIC);
	node_private_t *other = duk_get_pointer(ctx, -1);
	duk_pop(ctx);
	bool deep = duk_to_boolean(ctx, 1);

	dom_node *result;
	dom_exception err;
	err = dom_document_import_node(priv->parent.node, other->node, deep, &result);
	if (err != DOM_NO_ERR) return 0;

	dukky_push_node(ctx, result);
	dom_node_unref(result);
	return 1;
%}

method Document::adoptNode()
%{
	if (!dukky_instanceof(ctx, 0, PROTO_NAME(NODE))) return 0;
	duk_get_prop_string(ctx, 0, PRIVATE_MAGIC);
	node_private_t *other = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	dom_node *result;
	dom_exception err;
	err = dom_document_adopt_node(priv->parent.node, other->node, &result);
	if (err != DOM_NO_ERR) return 0;

	dukky_push_node(ctx, result);
	dom_node_unref(result);
	return 1;
%}

method Document::createDocumentFragment()
%{
	struct dom_document_fragment *frag = NULL;
	dom_exception err;

	err = dom_document_create_document_fragment(priv->parent.node, &frag);

	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	dukky_push_node(ctx, (dom_node *)frag);

	dom_node_unref(frag); /* The pushed node holds the reference now */

	return 1;
%}

getter Document::head()
%{
	struct dom_nodelist *nodes;
	struct dom_node *retnode;
	dom_exception err;
	err = dom_document_get_elements_by_tag_name(priv->parent.node,
						    corestring_dom_HEAD,
						    &nodes);
	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	err = dom_nodelist_item(nodes, 0, &retnode);

	if (err != DOM_NO_ERR) {
		dom_nodelist_unref(nodes);
		return 0; /* coerced to undefined */
	}

	dom_nodelist_unref(nodes);

	if (retnode == NULL) return 0; /* coerced to undefined */

	dukky_push_node(ctx, retnode);

	dom_node_unref(retnode);

	return 1;
%}

getter Document::body()
%{
	struct dom_nodelist *nodes;
	struct dom_node *retnode;
	dom_exception err;
	err = dom_document_get_elements_by_tag_name(priv->parent.node,
						    corestring_dom_BODY,
						    &nodes);
	if (err != DOM_NO_ERR) {
		return 0; /* coerced to undefined */
	}

	err = dom_nodelist_item(nodes, 0, &retnode);

	if (err != DOM_NO_ERR) {
		dom_nodelist_unref(nodes);
		return 0; /* coerced to undefined */
	}

	dom_nodelist_unref(nodes);

	if (retnode != NULL) {
		dukky_push_node(ctx, retnode);

		dom_node_unref(retnode);

		return 1;
	}

	return 0; /* coerced to undefined */
%}

setter Document::body()
%{
	dom_node *new_body;
	dom_node *old_body = NULL;
	dom_exception err;

	/* Get the node to set as body */
	duk_get_prop_string(ctx, 0, PRIVATE_MAGIC);
	node_private_t *new_priv = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	if (new_priv == NULL || new_priv->node == NULL) {
		return duk_error(ctx, DUK_ERR_TYPE_ERROR, "Invalid node for body");
	}
	new_body = new_priv->node;

	/* Verify it's a <body> or <frameset> */
	dom_string *name;
	dom_node_get_node_name(new_body, &name);
	bool matches = (name == corestring_dom_BODY) || (name == corestring_dom_FRAMESET);
	if (!matches) {
		dom_string_unref(name);
		return duk_error(ctx, DUK_ERR_ERROR, "Body must be BODY or FRAMESET element");
	}
	dom_string_unref(name);

	/* Find existing body */
	err = dom_html_document_get_body((dom_html_document *)priv->parent.node, (dom_html_element **)&old_body);
	if (err != DOM_NO_ERR) old_body = NULL;

	dom_node *parent;
	if (old_body != NULL) {
		err = dom_node_get_parent_node(old_body, &parent);
		if (err == DOM_NO_ERR && parent != NULL) {
			dom_node *replaced;
			err = dom_node_replace_child(parent, new_body, old_body, &replaced);
			if (err == DOM_NO_ERR) dom_node_unref(replaced);
			dom_node_unref(parent);
		}
		dom_node_unref(old_body);
	} else {
		/* No old body, append to documentElement */
		dom_element *doc_ele;
		err = dom_document_get_document_element(priv->parent.node, &doc_ele);
		if (err == DOM_NO_ERR && doc_ele != NULL) {
			dom_node *appended;
			err = dom_node_append_child((dom_node *)doc_ele, new_body, &appended);
			if (err == DOM_NO_ERR) dom_node_unref(appended);
			dom_node_unref(doc_ele);
		}
	}

	return 0;
%}

getter Document::location()
%{
	/* retrieve the location object from the root object (window) */
	duk_push_global_object(ctx);
	duk_get_prop_string(ctx, -1, "location");
	if (duk_is_undefined(ctx, -1)) {
		duk_pop(ctx);
		return 0;
	}
	return 1;
%}

getter Document::firstElementChild()
%{
	dom_node *element;
	dom_exception exc;
	dom_node_type node_type;
	dom_node *next_node;

	exc = dom_node_get_first_child(priv->parent.node, &element);
	if (exc != DOM_NO_ERR) {
		return 0;
	}

	while (element != NULL) {
		exc = dom_node_get_node_type(element, &node_type);
		if ((exc == DOM_NO_ERR) && (node_type == DOM_ELEMENT_NODE)) {
			/* found it */
			break;
		}

		exc = dom_node_get_next_sibling(element, &next_node);
		dom_node_unref(element);
		if (exc == DOM_NO_ERR) {
			element = next_node;
		} else {
			element = NULL;
		}
	}
	if (dukky_push_node(ctx, (dom_node *)element) == false) {
		dom_node_unref(element);
		return 0;
	}
	dom_node_unref(element);
	return 1;
%}

getter Document::lastElementChild()
%{
	dom_node *element;
	dom_exception exc;
	dom_node_type node_type;
	dom_node *next_node;

	exc = dom_node_get_last_child(priv->parent.node, &element);
	if (exc != DOM_NO_ERR) {
		return 0;
	}

	while (element != NULL) {
		exc = dom_node_get_node_type(element, &node_type);
		if ((exc == DOM_NO_ERR) && (node_type == DOM_ELEMENT_NODE)) {
			/* found it */
			break;
		}

		exc = dom_node_get_previous_sibling(element, &next_node);
		dom_node_unref(element);
		if (exc == DOM_NO_ERR) {
			element = next_node;
		} else {
			element = NULL;
		}
	}
	if (dukky_push_node(ctx, (dom_node *)element) == false) {
		dom_node_unref(element);
		return 0;
	}
	dom_node_unref(element);
	return 1;
%}

method Document::prepend()
%{
	dom_exception exc;
	dukky_push_generics(ctx, "mutationHelper");
	duk_push_array(ctx);
	for (int i = 0; i < duk_get_top(ctx) - 2; i++) {
		duk_dup(ctx, i);
		duk_put_prop_index(ctx, -2, i);
	}
	duk_push_this(ctx);
	if (dukky_pcall(ctx, 2, false) != 0) return 0;

	/* result is the node or fragment to prepend */
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	node_private_t *other = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	dom_node *first;
	exc = dom_node_get_first_child(priv->parent.node, &first);
	if (exc != DOM_NO_ERR) return 0;
	dom_node *spare;
	exc = dom_node_insert_before(priv->parent.node, other->node, first, &spare);
	if (first) dom_node_unref(first);
	if (exc != DOM_NO_ERR) return 0;
	dom_node_unref(spare);
	return 0;
%}

method Document::append()
%{
	dom_exception exc;
	dukky_push_generics(ctx, "mutationHelper");
	duk_push_array(ctx);
	for (int i = 0; i < duk_get_top(ctx) - 2; i++) {
		duk_dup(ctx, i);
		duk_put_prop_index(ctx, -2, i);
	}
	duk_push_this(ctx);
	if (dukky_pcall(ctx, 2, false) != 0) return 0;

	/* result is the node or fragment to append */
	duk_get_prop_string(ctx, -1, PRIVATE_MAGIC);
	node_private_t *other = duk_get_pointer(ctx, -1);
	duk_pop(ctx);

	dom_node *spare;
	exc = dom_node_append_child(priv->parent.node, other->node, &spare);
	if (exc != DOM_NO_ERR) return 0;
	dom_node_unref(spare);
	return 0;
%}

getter Document::childElementCount()
%{
	dom_node *element;
	dom_exception exc;
	dom_node_type node_type;
	dom_node *next_node;
	duk_uint_t jsret = 0;

	exc = dom_node_get_first_child(priv->parent.node, &element);
	if (exc != DOM_NO_ERR) {
		return 0;
	}

	while (element != NULL) {
		exc = dom_node_get_node_type(element, &node_type);
		if ((exc == DOM_NO_ERR) && (node_type == DOM_ELEMENT_NODE)) {
			jsret += 1;
		}

		exc = dom_node_get_next_sibling(element, &next_node);
		dom_node_unref(element);
		if (exc == DOM_NO_ERR) {
			element = next_node;
		} else {
			element = NULL;
		}
	}
	duk_push_uint(ctx, jsret);
	return 1;
%}

getter Document::children()
%{
	duk_uarridx_t idx = 0;
	duk_push_array(ctx);
	int arr_idx = duk_normalize_index(ctx, -1);

	dukky_push_children(ctx, priv->parent.node, arr_idx, &idx);

	/* Wrap result array in a proxy to make it look like a NodeList/HTMLCollection */
	dukky_push_generics(ctx, "makeListProxy");
	duk_insert(ctx, -2);
	if (dukky_pcall(ctx, 1, false) != 0) {
		return 0;
	}

	return 1;
%}


method Document::getElementById()
%{
	dom_string *elementId_dom;
	dom_element *element;
	dom_exception exc;
	duk_size_t text_len;
	const char *text = duk_safe_to_lstring(ctx, 0, &text_len);

	exc = dom_string_create((const uint8_t *)text, text_len, &elementId_dom);
	if (exc != DOM_NO_ERR) {
		return 0;
	}

	exc = dom_document_get_element_by_id(priv->parent.node,
					     elementId_dom, &element);
	dom_string_unref(elementId_dom);
	if (exc != DOM_NO_ERR) {
		return 0;
	}

	if (element != NULL) {
		dukky_push_node(ctx, (dom_node *)element);
		dom_node_unref(element);
		return 1;
	}

	return 0;
%}

getter Document::documentElement()
%{
	dom_exception exc;
	dom_element *element;

	exc = dom_document_get_document_element(priv->parent.node,
						&element);
	if (exc != DOM_NO_ERR) {
		return 0;
	}

	if (element == NULL) {
		return 0;
	}

	dukky_push_node(ctx, (dom_node *)element);
	dom_node_unref(element);

	return 1;

%}

method Document::getElementsByTagName()
%{
	dom_nodelist *nodes;
	dom_exception err;
	duk_size_t text_len;
	const char *text = duk_safe_to_lstring(ctx, 0, &text_len);
	dom_string *tag;

	err = dom_string_create((const uint8_t *)text, text_len, &tag);

	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	err = dom_document_get_elements_by_tag_name(priv->parent.node,
						    tag, &nodes);
	dom_string_unref(tag);
	if (err != DOM_NO_ERR) return 0; /* coerced to undefined */

	if (nodes == NULL) return 0; /* coerced to undefined */

	dukky_push_generics(ctx, "makeListProxy");

	duk_push_pointer(ctx, nodes);
	dukky_create_object(ctx, PROTO_NAME(NODELIST), 1);
	dom_nodelist_unref(nodes);

	if (dukky_pcall(ctx, 1, false) != 0) {
		NSLOG(dukky, DEBUG, "Unable to construct nodelist?");
		return 0; /* coerced to undefined */
	}

	return 1; /* The Proxy(NodeList) wrapper */
%}

method Document::getElementsByClassName()
%{
	duk_size_t clen;
	const char *cls = duk_to_lstring(ctx, 0, &clen);
	duk_push_array(ctx);
	int arr_idx = duk_normalize_index(ctx, -1);
	duk_uarridx_t idx = 0;

	dukky_getElementsByClassName_recursive(ctx, priv->parent.node, cls, clen, &idx, arr_idx);

	/* Wrap result array in a proxy to make it look like a NodeList */
	dukky_push_generics(ctx, "makeListProxy");
	duk_insert(ctx, -2);
	if (dukky_pcall(ctx, 1, false) != 0) {
		return 0;
	}

	return 1;
%}


getter Document::cookie()
%{
	char *cookie_str;
	struct html_content *htmlc;
	dom_exception err;

	if (priv == NULL || priv->parent.node == NULL) return 0;

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		cookie_str = urldb_get_cookie(llcache_handle_get_url(htmlc->base.llcache), false);
		if (cookie_str != NULL) {
			duk_push_string(ctx, cookie_str);
			free(cookie_str);
		} else {
			duk_push_string(ctx, "");
		}
		return 1;
	} else {
		NSLOG(netsurf, INFO,
		      "error getting htmlc. parent node:%p htmlc:%p",
		      priv->parent.node, htmlc);
	}
	return 0;
%}

setter Document::cookie()
%{
	struct html_content *htmlc;
	dom_exception err;

	const char * cookie_str = duk_safe_to_string(ctx, 0);

	if (priv == NULL || priv->parent.node == NULL) return 0;

	err = dom_node_get_user_data(priv->parent.node,
				     corestring_dom___ns_key_html_content_data,
				     &htmlc);
	if ((err == DOM_NO_ERR) && (htmlc != NULL)) {
		/* At this point we need to get the given cookie string parsed
		 * and inserted into the urldb
		 */
		bool ok = urldb_set_cookie(cookie_str, /* The cookie string to set */
					   /* The location to set the cookie for */
					   llcache_handle_get_url(htmlc->base.llcache),
					   NULL); /* The referer, which we trust */
		if (!ok) {
			NSLOG(netsurf, DEEPDEBUG, "unable to set cookie: %s", cookie_str);
			/* However there's no useful way to signal that to JS */
		}
	} else {
		NSLOG(netsurf, INFO,
		      "error getting htmlc. parent node:%p htmlc:%p",
		      priv->parent.node, htmlc);
	}
	return 0;
%}

