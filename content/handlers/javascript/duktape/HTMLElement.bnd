method HTMLElement::click()
%{
	/* Simple implementation of click() - fire a click event */
	dom_event *evt;
	if (dom_event_create(&evt) == DOM_NO_ERR) {
		dom_event_init(evt, corestring_dom_click, true, true);
		bool status;
		dom_event_target_dispatch_event(priv->parent.parent.node, evt, &status);
		dom_event_unref(evt);
	}
	return 0;
%}

