getter HTMLImageElement::isMap()
%{
	dom_exception err;
	bool res;

	err = dom_html_image_element_get_is_map((dom_html_image_element *)priv->parent.parent.parent.node, &res);
	if (err != DOM_NO_ERR) return 0;

	duk_push_boolean(ctx, res);
	return 1;
%}

setter HTMLImageElement::isMap()
%{
	dom_exception err;
	bool res = duk_to_boolean(ctx, 0);

	err = dom_html_image_element_set_is_map((dom_html_image_element *)priv->parent.parent.parent.node, res);
	if (err != DOM_NO_ERR) return 0;

	return 0;
%}

