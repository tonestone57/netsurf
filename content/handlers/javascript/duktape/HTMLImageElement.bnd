prologue HTMLImageElement()
%{
#include "utils/corestrings.h"
#include "content/hlcache.h"
#include "content/content_protected.h"
#include "html/box.h"
%}

init HTMLImageElement(struct dom_html_element *html_image_element::html_element);

getter HTMLImageElement::naturalWidth()
%{
	dom_exception err;
	struct box *box;
	int width = 0;

	err = dom_node_get_user_data(priv->parent.parent.parent.node,
				     corestring_dom___ns_key_box_node_data,
				     (void **)&box);
	if (err == DOM_NO_ERR && box != NULL && box->object != NULL) {
		struct content *c = hlcache_handle_get_content(box->object);
		if (c != NULL) {
			width = content_get_width(box->object);
		}
	}

	duk_push_uint(ctx, (duk_uint_t)width);
	return 1;
%}

getter HTMLImageElement::naturalHeight()
%{
	dom_exception err;
	struct box *box;
	int height = 0;

	err = dom_node_get_user_data(priv->parent.parent.parent.node,
				     corestring_dom___ns_key_box_node_data,
				     (void **)&box);
	if (err == DOM_NO_ERR && box != NULL && box->object != NULL) {
		struct content *c = hlcache_handle_get_content(box->object);
		if (c != NULL) {
			height = content_get_height(box->object);
		}
	}

	duk_push_uint(ctx, (duk_uint_t)height);
	return 1;
%}

getter HTMLImageElement::align()
%{
	dom_exception err;
	dom_string *str;

	err = dom_html_image_element_get_align((dom_html_image_element *)priv->parent.parent.parent.node, &str);
	if (err != DOM_NO_ERR || str == NULL) {
		duk_push_string(ctx, "");
		return 1;
	}

	duk_push_lstring(ctx, dom_string_data(str), dom_string_byte_length(str));
	dom_string_unref(str);
	return 1;
%}

setter HTMLImageElement::align()
%{
	dom_exception err;
	dom_string *str;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);

	err = dom_string_create((const uint8_t *)s, slen, &str);
	if (err != DOM_NO_ERR) return 0;

	err = dom_html_image_element_set_align((dom_html_image_element *)priv->parent.parent.parent.node, str);
	dom_string_unref(str);
	return 0;
%}

