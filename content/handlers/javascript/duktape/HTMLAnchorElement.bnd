getter HTMLAnchorElement::text()
%{
	dom_exception err;
	dom_string *content;

	err = dom_node_get_text_content((dom_node *)priv->parent.parent.parent.node, &content);
	if (err != DOM_NO_ERR) return 0;

	if (content != NULL) {
		duk_push_lstring(ctx, dom_string_data(content), dom_string_length(content));
		dom_string_unref(content);
		return 1;
	}

	duk_push_string(ctx, "");
	return 1;
%}

setter HTMLAnchorElement::text()
%{
	dom_exception err;
	dom_string *content;
	duk_size_t slen;
	const char *s = duk_safe_to_lstring(ctx, 0, &slen);

	err = dom_string_create((const uint8_t *)s, slen, &content);
	if (err != DOM_NO_ERR) return 0;

	err = dom_node_set_text_content((dom_node *)priv->parent.parent.parent.node, content);
	dom_string_unref(content);
	if (err != DOM_NO_ERR) return 0;

	return 0;
%}




