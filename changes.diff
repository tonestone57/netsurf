+		xhr->xhr_obj = JS_UNDEFINED;
+		JS_FreeValue(xhr->ctx, obj);
+		break;
+	case FETCH_ERROR:
+		xhr->ready_state = 4; /* DONE */
+		qjsky_xhr_on_state_change(xhr, xhr->xhr_obj);
+
+		JSValue obj_err = xhr->xhr_obj;
+		xhr->xhr_obj = JS_UNDEFINED;
+		JS_FreeValue(xhr->ctx, obj_err);
+		break;
+	default:
+		break;
+	}
