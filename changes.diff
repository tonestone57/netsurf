diff --git a/content/handlers/javascript/quickjs/Makefile b/content/handlers/javascript/quickjs/Makefile
index 800ec3705..f3ccead6d 100644
--- a/content/handlers/javascript/quickjs/Makefile
+++ b/content/handlers/javascript/quickjs/Makefile
@@ -2,7 +2,7 @@
 # NetSurf QuickJS source file inclusion
 #

-S_JAVASCRIPT += quickjs/quickjs.c quickjs/qjsky.c quickjs/xhr.c quickjs/qjs_utils.c
+S_JAVASCRIPT += quickjs/quickjs.c quickjs/qjsky.c quickjs/xhr.c quickjs/location.c quickjs/history.c quickjs/navigator.c quickjs/qjs_utils.c

 # Rule to invoke nsgenbind with the QuickJS backend.
 # Note: This requires an updated version of nsgenbind that supports -t qjs_libdom.
@@ -17,7 +17,34 @@ $(OBJROOT)/quickjs/binding.h $(OBJROOT)/quickjs/Makefile: content/handlers/javas
		false; \
	)

+# Generator for the C include representing the generics.js
+$(OBJROOT)/quickjs/generics.js.inc: content/handlers/javascript/duktape/generics.js $(TOOLROOT)/xxd
+	$(Q)$(MKDIR) -p $(OBJROOT)/quickjs
+	$(VQ)echo "     XXD: $<"
+	$(Q)$(TOOLROOT)/xxd -i $< $@.tmp
+	$(Q)sed -e 's/content_handlers_javascript_duktape_generics_js/generics_js/' $@.tmp > $@
+
+# Generator for the C include representing the polyfill.js
+$(OBJROOT)/quickjs/polyfill.js.inc: content/handlers/javascript/duktape/polyfill.js $(TOOLROOT)/xxd
+	$(Q)$(MKDIR) -p $(OBJROOT)/quickjs
+	$(VQ)echo "     XXD: $<"
+	$(Q)$(TOOLROOT)/xxd -i $< $@.tmp
+	$(Q)sed -e 's/content_handlers_javascript_duktape_polyfill_js/polyfill_js/' $@.tmp > $@
+
 # Link against quickjs.
-# Use pkg-config if available, otherwise fallback to -lquickjs.
-CFLAGS += $(shell pkg-config --cflags quickjs 2>/dev/null || echo "")
-LDFLAGS += $(shell pkg-config --libs quickjs 2>/dev/null || echo "-lquickjs")
+# Use pkg-config if available, otherwise fallback to standard paths.
+QJS_CFLAGS := $(shell pkg-config --cflags quickjs 2>/dev/null)
+ifeq ($(QJS_CFLAGS),)
+  QJS_CFLAGS := -I/usr/include/quickjs
+endif
+CFLAGS += $(QJS_CFLAGS)
+
+QJS_LDFLAGS := $(shell pkg-config --libs quickjs 2>/dev/null)
+ifeq ($(QJS_LDFLAGS),)
+  QJS_LDFLAGS := -L/usr/lib/quickjs -lquickjs
+endif
+LDFLAGS += $(QJS_LDFLAGS)
+
+# Add dependencies for objects
+$(OBJROOT)/content_handlers_javascript_quickjs_qjsky.o: $(OBJROOT)/quickjs/generics.js.inc $(OBJROOT)/quickjs/polyfill.js.inc
+$(OBJROOT)/content_handlers_javascript_quickjs_quickjs.o: $(OBJROOT)/quickjs/generics.js.inc $(OBJROOT)/quickjs/polyfill.js.inc
diff --git a/content/handlers/javascript/quickjs/history.c b/content/handlers/javascript/quickjs/history.c
new file mode 100644
index 000000000..62cf523e3
--- /dev/null
+++ b/content/handlers/javascript/quickjs/history.c
@@ -0,0 +1,63 @@
+#include <stdlib.h>
+#include <quickjs.h>
+#include "content/handlers/javascript/quickjs/history.h"
+#include "content/handlers/javascript/quickjs/qjs_internal.h"
+#include "desktop/browser_history.h"
+#include "netsurf/browser_window.h"
+
+JSClassDef qjsky_history_class = {
+	"History",
+	.finalizer = NULL,
+};
+
+static JSValue qjsky_history_back(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+	struct jsthread *thread = JS_GetContextOpaque(ctx);
+	if (thread && thread->win_priv) {
+		browser_window_history_back(thread->win_priv, false);
+	}
+	return JS_UNDEFINED;
+}
+
+static JSValue qjsky_history_forward(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+	struct jsthread *thread = JS_GetContextOpaque(ctx);
+	if (thread && thread->win_priv) {
+		browser_window_history_forward(thread->win_priv, false);
+	}
+	return JS_UNDEFINED;
+}
+
+static JSValue qjsky_history_go(JSContext *ctx, JSValueConst this_val, int argc, JSValueConst *argv)
+{
+	struct jsthread *thread = JS_GetContextOpaque(ctx);
+	if (thread && thread->win_priv && argc > 0) {
+		int delta;
+		JS_ToInt32(ctx, &delta, argv[0]);
+		/* Simple implementation for now */
+		if (delta < 0) browser_window_history_back(thread->win_priv, false);
+		else if (delta > 0) browser_window_history_forward(thread->win_priv, false);
+	}
+	return JS_UNDEFINED;
+}
+
+static const JSCFunctionListEntry qjsky_history_proto_funcs[] = {
+	JS_CFUNC_DEF("back", 0, qjsky_history_back),
+	JS_CFUNC_DEF("forward", 0, qjsky_history_forward),
+	JS_CFUNC_DEF("go", 1, qjsky_history_go),
+};
+
+void qjsky_init_history(JSContext *ctx)
+{
+	struct jsheap *heap = JS_GetRuntimeOpaque(JS_GetRuntime(ctx));
+
+	JSValue proto = JS_NewObject(ctx);
+	JS_SetPropertyFunctionList(ctx, proto, qjsky_history_proto_funcs, sizeof(qjsky_history_proto_funcs)/sizeof(qjsky_history_proto_funcs[0]));
+	JS_SetClassProto(ctx, heap->history_class_id, proto);
+}
+
+JSValue qjsky_create_history(JSContext *ctx)
+{
+	struct jsheap *heap = JS_GetRuntimeOpaque(JS_GetRuntime(ctx));
+	return JS_NewObjectClass(ctx, heap->history_class_id);
+}
