+static void qjs_run_jobs(JSContext *ctx)
+{
+	JSContext *ctx1;
+	int err;
+	for (;;) {
+		err = JS_ExecutePendingJob(JS_GetRuntime(ctx), &ctx1);
+		if (err <= 0) {
+			if (err < 0) qjs_log_exception(ctx1, "Pending job error");
